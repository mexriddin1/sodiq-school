# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sodiq_school

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Default seed admin
SEED_ADMIN_EMAIL=developer@gmail.com
SEED_ADMIN_PASSWORD=developer$123
SEED_ADMIN_NAME=Developer

# Uploads
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:4000

# Lead email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
LEAD_NOTIFY_TO=scaleup.corporate@gmail.com

# Meta Conversion API (server-side Pixel events sent on lead submit)
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional: test code from Events Manager > Test Events
META_TEST_EVENT_CODE=
META_CAPI_DEBUG=false
