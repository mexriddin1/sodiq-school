/* ---------- Reset & base ---------- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  max-width: 100%;
}
body {
  font-family: 'Montserrat', system-ui, -apple-system, sans-serif;
  font-weight: 400;
  color: #06113C;
  background: #FFFFFF;
  line-height: 1.55;
  overflow-x: hidden;
  max-width: 100%;
  width: 100%;
  position: relative;
}
h1, h2, h3, p, a, li { overflow-wrap: break-word; word-wrap: break-word; }
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }
ul { list-style: none; }
input, select, textarea { font-family: inherit; font-size: inherit; }

:root {
  --navy: #06113C;
  --navy-90: rgba(6, 17, 60, 0.9);
  --navy-70: rgba(6, 17, 60, 0.7);
  --navy-50: rgba(6, 17, 60, 0.5);
  --navy-20: rgba(6, 17, 60, 0.2);
  --navy-10: rgba(6, 17, 60, 0.1);
  --orange: #FF8A32;
  --gray-light: #ECECEC;
  --gray-mid: #DBDBDB;
  --white: #FFFFFF;
  --max: 1240px;
  --radius: 8px;
  --pad-x: clamp(20px, 5vw, 64px);
  --section-y: clamp(72px, 9vw, 120px);
}

.container {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--pad-x);
  width: 100%;
}

section { padding: var(--section-y) 0; position: relative; overflow: hidden; }

/* ---------- Typography ---------- */
h1, h2, h3, h4, h5 { font-family: 'Montserrat', sans-serif; line-height: 1.15; letter-spacing: -0.01em; font-weight: 700; }
h1 { font-size: clamp(2.4rem, 5.5vw, 4.4rem); }
h2 { font-size: clamp(1.9rem, 3.6vw, 2.9rem); }
h3 { font-size: clamp(1.25rem, 2vw, 1.5rem); }
p  { font-size: 1rem; }

.eyebrow {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--orange);
}
.pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--orange);
  color: #fff;
  padding: 8px 16px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.pill .dot { width: 6px; height: 6px; border-radius: 50%; background: #fff; }

/* ---------- Buttons ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 14px 26px;
  font-weight: 600;
  font-size: 0.95rem;
  border-radius: var(--radius);
  transition: transform .2s ease, background .2s ease, color .2s ease, box-shadow .2s ease;
  cursor: pointer;
  white-space: nowrap;
}
.btn-primary {
  background: var(--orange);
  color: #fff;
  box-shadow: 0 6px 18px rgba(255, 138, 50, 0.35);
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(255, 138, 50, 0.45); }
.btn-large { padding: 18px 32px; font-size: 1rem; }
.btn-block { width: 100%; }
.btn-ghost-light { color: #fff; border: 1px solid rgba(255,255,255,0.3); }
.btn-ghost-light:hover { background: rgba(255,255,255,0.08); }

.text-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-weight: 600;
  color: var(--navy);
  border-bottom: 1px solid var(--navy-20);
  padding-bottom: 2px;
  transition: border-color .2s, color .2s;
}
.text-link:hover { color: var(--orange); border-color: var(--orange); }
.text-link.on-dark { color: #fff; border-color: rgba(255,255,255,0.3); }
.text-link.on-dark:hover { color: var(--orange); border-color: var(--orange); }

/* ---------- Header ---------- */
.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: transparent;
  transition: background .25s, box-shadow .25s, padding .25s;
  padding: 18px 0;
}
.header.scrolled,
.header.solid {
  background: #fff;
  box-shadow: 0 2px 16px rgba(6, 17, 60, 0.08);
  padding: 12px 0;
}
.header-inner {
  display: flex; align-items: center; justify-content: space-between; gap: 24px;
}
.logo {
  display: flex; align-items: center; gap: 12px;
  color: #fff;
  transition: color .25s;
}
.header.scrolled .logo,
.header.solid .logo { color: var(--navy); }
.logo-mark {
  width: 36px; height: 40px;
  display: block;
  flex-shrink: 0;
}
.logo-text {
  font-weight: 700;
  font-size: 0.95rem;
  letter-spacing: 0.14em;
  line-height: 1;
}
.logo-text small {
  display: block;
  font-weight: 500;
  font-size: 0.62rem;
  letter-spacing: 0.22em;
  opacity: 0.6;
  margin-top: 4px;
}
.nav {
  display: flex; align-items: center; gap: 32px;
}
.nav a {
  font-size: 0.88rem;
  font-weight: 500;
  color: rgba(255,255,255,0.85);
  transition: color .2s;
  position: relative;
}
.header.scrolled .nav a,
.header.solid .nav a { color: var(--navy); }
.nav a:hover { color: var(--orange); }
.nav a.active { color: var(--orange); }
.nav a.active::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  bottom: -6px;
  height: 2px;
  background: var(--orange);
  border-radius: 2px;
}
.header-cta { display: flex; align-items: center; gap: 16px; }
.hamburger {
  display: none;
  width: 40px; height: 40px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  position: relative;
  z-index: 110;
}
.hamburger span {
  width: 22px; height: 2px;
  background: #fff;
  transition: .2s;
}
.header.scrolled .hamburger span,
.header.solid .hamburger span { background: var(--navy); }
.hamburger.open span { background: var(--navy); }
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

@media (max-width: 1024px) {
  .nav { gap: 22px; }
  .nav a { font-size: 0.82rem; }
}
@media (max-width: 900px) {
  .hamburger { display: flex; }
  .nav {
    position: fixed;
    top: 0; right: 0;
    width: min(320px, 80vw);
    height: 100vh;
    background: #fff;
    flex-direction: column;
    align-items: flex-start;
    padding: 100px 32px 40px;
    gap: 22px;
    transform: translateX(100%);
    transition: transform .3s ease;
    box-shadow: -8px 0 30px rgba(0,0,0,0.1);
  }
  .nav.open { transform: translateX(0); }
  .nav a { color: var(--navy) !important; font-size: 1rem; }
  .nav a.active { color: var(--orange) !important; }
  .nav a.active::after { display: none; }
  .header-cta .btn-primary { display: none; }
}

/* ---------- HERO ---------- */
.hero {
  background: var(--navy);
  color: #fff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 140px 0 60px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(135deg, transparent 0%, transparent 49.5%, rgba(255,138,50,0.06) 49.5%, rgba(255,138,50,0.06) 50.5%, transparent 50.5%),
    linear-gradient(45deg, transparent 0%, transparent 49.7%, rgba(255,255,255,0.04) 49.7%, rgba(255,255,255,0.04) 50.3%, transparent 50.3%);
  background-size: 60px 60px, 80px 80px;
  pointer-events: none;
  opacity: 0.7;
}
.hero::after {
  content: '';
  position: absolute;
  right: -10%;
  top: 10%;
  width: 700px; height: 700px;
  background: radial-gradient(circle, rgba(255,138,50,0.08) 0%, transparent 60%);
  pointer-events: none;
}
.hero-inner { position: relative; z-index: 2; }
.hero h1 {
  margin: 24px 0 20px;
  max-width: 14ch;
  text-wrap: balance;
}
.hero p.lead {
  color: rgba(255,255,255,0.72);
  font-size: clamp(1rem, 1.4vw, 1.18rem);
  max-width: 56ch;
  line-height: 1.6;
  margin-bottom: 40px;
}
.hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 24px; margin-bottom: 64px; }
.hero-actions .text-link.on-dark {
  border: none;
  border-bottom: 1px solid rgba(255,255,255,0.3);
}
.hero-stats {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius);
  overflow: hidden;
  backdrop-filter: blur(6px);
}
.hero-stat {
  background: rgba(255,255,255,0.04);
  padding: 28px 22px;
  text-align: left;
}
.hero-stat .num {
  font-size: clamp(1.5rem, 2.2vw, 2rem);
  font-weight: 700;
  color: var(--orange);
  letter-spacing: -0.02em;
  line-height: 1;
}
.hero-stat .lbl {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.7);
  margin-top: 8px;
  letter-spacing: 0.04em;
}
.hero-stat .sub {
  font-size: 0.7rem;
  color: rgba(255,255,255,0.5);
  margin-top: 6px;
  line-height: 1.4;
}
.scroll-indicator {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.5);
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  z-index: 2;
}
.scroll-indicator .arrow {
  width: 1px; height: 36px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.5));
  animation: scrollArrow 2s ease-in-out infinite;
}
@keyframes scrollArrow {
  0%, 100% { opacity: 0.3; transform: scaleY(1); }
  50% { opacity: 1; transform: scaleY(1.3); }
}
@media (max-width: 1100px) {
  .hero-stats { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 720px) {
  .hero-stats { grid-template-columns: repeat(2, 1fr); }
  .hero-stat { padding: 20px 14px; }
  .hero-stat .sub { font-size: 0.66rem; }
}
@media (max-width: 380px) {
  .hero-stats { grid-template-columns: 1fr; }
}

/* ---------- PAGE HERO (inner pages) ---------- */
.page-hero {
  background: var(--navy);
  color: #fff;
  padding: 160px 0 80px;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.page-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(135deg, transparent 0%, transparent 49.5%, rgba(255,138,50,0.06) 49.5%, rgba(255,138,50,0.06) 50.5%, transparent 50.5%);
  background-size: 60px 60px;
  pointer-events: none;
  opacity: 0.7;
}
.page-hero::after {
  content: '';
  position: absolute;
  right: -10%;
  top: -20%;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(255,138,50,0.08) 0%, transparent 60%);
  pointer-events: none;
}
.page-hero-inner { position: relative; z-index: 2; }
.page-hero .eyebrow { color: var(--orange); }
.page-hero h1 {
  font-size: clamp(2rem, 4.4vw, 3.4rem);
  margin: 14px 0 18px;
  text-wrap: balance;
}
.page-hero p.lead {
  color: rgba(255,255,255,0.72);
  font-size: clamp(1rem, 1.4vw, 1.12rem);
  max-width: 56ch;
  line-height: 1.6;
  margin: 0 auto;
}
.crumbs {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.55);
  margin-bottom: 8px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.crumbs a { color: rgba(255,255,255,0.7); transition: color .2s; }
.crumbs a:hover { color: var(--orange); }
.crumbs .sep { opacity: 0.4; }

/* ---------- BIZ HAQIMIZDA ---------- */
.about { background: #fff; }
.about-grid {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 80px;
  align-items: start;
}
.about h2 { margin: 14px 0 28px; max-width: 18ch; text-wrap: balance; }
.about p { color: var(--navy-90); margin-bottom: 18px; max-width: 56ch; }
.about-card {
  background: #fff;
  border-left: 3px solid var(--navy);
  padding: 8px 28px;
  display: grid;
  gap: 26px;
}
.about-card .row { display: flex; flex-direction: column; gap: 4px; }
.about-card .row .lbl {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--navy-50);
  font-weight: 600;
}
.about-card .row .val {
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--navy);
  letter-spacing: -0.01em;
}
.about-card .row .val .accent { color: var(--orange); }
@media (max-width: 880px) {
  .about-grid { grid-template-columns: 1fr; gap: 48px; }
}

/* ---------- MISSION ---------- */
.mission {
  background: var(--navy);
  color: #fff;
  text-align: center;
  overflow: hidden;
  position: relative;
}
.mission::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: linear-gradient(135deg, transparent 0%, transparent 49.7%, rgba(255,255,255,0.03) 49.7%, rgba(255,255,255,0.03) 50.3%, transparent 50.3%);
  background-size: 80px 80px;
  pointer-events: none;
}
.mission-inner {
  max-width: 920px;
  margin: 0 auto;
  position: relative;
  padding: 0 var(--pad-x);
}
.mission .quote-mark {
  color: var(--orange);
  font-size: 5rem;
  line-height: 0.8;
  font-weight: 700;
  font-family: 'Georgia', serif;
  display: block;
  margin-bottom: 24px;
}
.mission .quote {
  font-size: clamp(1.4rem, 2.6vw, 2.1rem);
  font-weight: 500;
  line-height: 1.4;
  text-wrap: balance;
  letter-spacing: -0.01em;
}
.mission .quote .accent { color: var(--orange); font-weight: 600; }
.mission .mission-sub {
  max-width: 640px;
  margin: 24px auto 0;
  color: rgba(255,255,255,0.6);
  font-size: 1rem;
  line-height: 1.7;
  text-align: center;
}
.mission .divider {
  width: 80px; height: 2px;
  background: var(--orange);
  margin: 40px auto 16px;
}
.mission .label {
  color: rgba(255,255,255,0.5);
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
}

/* ---------- RESULTS ---------- */
.results { background: #fff; }
.section-head { text-align: center; margin-bottom: 60px; }
.section-head .eyebrow { color: var(--orange); }
.section-head h2 { margin-top: 12px; max-width: 22ch; margin-left: auto; margin-right: auto; text-wrap: balance; }
.section-head .sub {
  color: var(--navy-70);
  margin-top: 14px;
  max-width: 50ch;
  margin-left: auto; margin-right: auto;
}

.stats-row {
  display: flex;
  justify-content: center;
  gap: 28px;
  margin-bottom: 80px;
  padding: 48px 28px;
  background: var(--gray-light);
  border-radius: 12px;
}
.stats-row .stat-big { flex: 1; max-width: 220px; }
.stat-big { text-align: center; }
.stat-big .num {
  font-size: clamp(2rem, 3.2vw, 2.8rem);
  font-weight: 700;
  color: var(--orange);
  letter-spacing: -0.02em;
  line-height: 1;
}
.stat-big .num .suffix { color: var(--orange); }
.stat-big .lbl {
  font-size: 0.85rem;
  color: var(--navy);
  margin-top: 12px;
  font-weight: 600;
  letter-spacing: 0.02em;
}
.stat-big .sub {
  font-size: 0.78rem;
  color: var(--navy-50);
  margin-top: 6px;
  line-height: 1.4;
}
@media (max-width: 1100px) {
  .stats-row { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 720px) {
  .stats-row { grid-template-columns: repeat(2, 1fr); padding: 32px 20px; gap: 24px; }
  .stat-big .sub { font-size: 0.7rem; }
}
@media (max-width: 380px) {
  .stats-row { grid-template-columns: 1fr; }
}

.tabs {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-bottom: 40px;
  background: var(--gray-light);
  padding: 6px;
  border-radius: 999px;
  width: fit-content;
  margin-left: auto;
  margin-right: auto;
}
.tab-btn {
  padding: 10px 28px;
  border-radius: 999px;
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--navy-70);
  transition: .2s;
}
.tab-btn.active { background: var(--navy); color: #fff; }

.results-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.result-card {
  background: #fff;
  border: 1px solid var(--navy-10);
  border-bottom: 3px solid var(--navy);
  border-radius: var(--radius);
  padding: 28px;
  display: flex;
  align-items: center;
  gap: 18px;
  transition: transform .2s, box-shadow .2s;
}
.result-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 28px rgba(6,17,60,0.08);
}
.avatar {
  width: 60px; height: 60px;
  border-radius: 50%;
  background: var(--navy);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-weight: 600;
  font-size: 1.1rem;
  flex-shrink: 0;
  background-size: cover;
  background-position: center;
}
.result-card .info { flex: 1; min-width: 0; }
.result-card .name { font-weight: 600; font-size: 1rem; color: var(--navy); }
.result-card .grade { font-size: 0.82rem; color: var(--navy-50); margin-top: 2px; }
.score-badge {
  background: var(--orange);
  color: #fff;
  font-weight: 700;
  font-size: 0.95rem;
  padding: 8px 14px;
  border-radius: 6px;
  letter-spacing: 0.02em;
}
.results-cta { text-align: center; margin-top: 48px; }
@media (max-width: 880px) {
  .results-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 560px) {
  .results-grid { grid-template-columns: 1fr; }
}
.tab-panel { display: none; }
.tab-panel.active { display: block; animation: fadeIn .3s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* ---------- ALUMNI ---------- */
.alumni { background: var(--gray-light); }
.alumni-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.alumni-card {
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(6,17,60,0.04);
  transition: transform .25s, box-shadow .25s;
}
.alumni-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 36px rgba(6,17,60,0.10);
}
.alumni-photo {
  aspect-ratio: 4/3;
  background: var(--navy);
  background-size: cover;
  background-position: center;
  position: relative;
}
.alumni-info { padding: 24px; }
.alumni-info .name { font-weight: 700; color: var(--navy); font-size: 1.05rem; }
.alumni-info .uni { color: var(--orange); font-size: 0.85rem; font-weight: 600; margin-top: 4px; letter-spacing: 0.02em; }
.alumni-info .major { color: var(--navy-70); font-size: 0.88rem; margin-top: 10px; }
.alumni-info .ielts {
  display: inline-block;
  margin-top: 14px;
  padding: 4px 10px;
  background: var(--gray-light);
  color: var(--navy);
  border-radius: 4px;
  font-size: 0.78rem;
  font-weight: 600;
}
@media (max-width: 880px) { .alumni-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .alumni-grid { grid-template-columns: 1fr; } }

/* ---------- UNIVERSITIES ---------- */
.unis { background: #fff; }
.uni-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
  max-width: 980px;
  margin: 0 auto;
}
.uni-pill {
  padding: 14px 26px;
  background: var(--gray-light);
  color: var(--navy);
  border-radius: 999px;
  font-weight: 600;
  font-size: 0.92rem;
  letter-spacing: 0.01em;
  transition: .2s;
}
.uni-pill:hover { background: var(--navy); color: #fff; }
.uni-divider { text-align: center; margin: 64px 0 28px; }
.uni-divider .eyebrow { color: var(--navy-50); }
.uni-bottom-stat {
  margin-top: 56px;
  text-align: center;
  color: var(--navy-70);
  font-size: 1.05rem;
}
.uni-bottom-stat strong { color: var(--orange); font-weight: 700; }

/* ---------- ADMISSIONS ---------- */
.admissions { padding: 0; background: var(--navy); color: #fff; }
.adm-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 600px;
}
.adm-left {
  padding: var(--section-y) var(--pad-x);
  display: flex; flex-direction: column; justify-content: center;
  background: var(--navy);
  position: relative;
  overflow: hidden;
}
.adm-left::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: linear-gradient(135deg, transparent 49.7%, rgba(255,138,50,0.06) 49.7%, rgba(255,138,50,0.06) 50.3%, transparent 50.3%);
  background-size: 60px 60px;
  pointer-events: none;
}
.adm-left > * { position: relative; }
.adm-left h2 { margin: 18px 0 36px; text-wrap: balance; max-width: 16ch; }
.adm-steps { display: flex; flex-direction: column; gap: 18px; margin-bottom: 36px; }
.adm-step {
  display: flex; align-items: center; gap: 18px;
  padding: 14px 0;
  border-top: 1px solid rgba(255,255,255,0.12);
}
.adm-step:last-child { border-bottom: 1px solid rgba(255,255,255,0.12); }
.adm-step .n {
  width: 36px; height: 36px;
  flex-shrink: 0;
  border: 1px solid var(--orange);
  color: var(--orange);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 600; font-size: 0.95rem;
}
.adm-step .lbl { font-weight: 500; }
.scarcity {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: rgba(255,138,50,0.12);
  border-left: 3px solid var(--orange);
  font-size: 0.88rem;
  color: rgba(255,255,255,0.9);
  margin-top: 8px;
}
.scarcity .icon { color: var(--orange); }

.adm-right {
  background: #fff;
  color: var(--navy);
  padding: var(--section-y) var(--pad-x);
  display: flex; flex-direction: column; justify-content: center;
}
.adm-tests {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-bottom: 32px;
}
.test-card {
  background: var(--gray-light);
  border-radius: 8px;
  padding: 20px 16px;
  text-align: center;
}
.test-card .ic {
  width: 32px; height: 32px;
  margin: 0 auto 12px;
  color: var(--orange);
}
.test-card .nm { font-weight: 600; font-size: 0.92rem; }
.adm-grades {
  background: var(--gray-light);
  padding: 16px 20px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
  font-size: 0.92rem;
}
.adm-grades .lbl { color: var(--navy-70); }
.adm-grades .val { font-weight: 700; color: var(--navy); font-size: 1.1rem; }
.adm-secondary {
  margin-top: 18px;
  color: var(--navy-70);
  font-size: 0.92rem;
  text-align: center;
}
.adm-secondary a { color: var(--navy); font-weight: 600; }
@media (max-width: 880px) {
  .adm-grid { grid-template-columns: 1fr; }
  .adm-left, .adm-right { padding: 64px var(--pad-x); }
}

/* ---------- TEAM ---------- */
.team { background: var(--navy); }
.team-sub {
  text-align: center;
  margin: 56px 0 24px;
  color: var(--navy);
  font-size: 0.78rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  font-weight: 600;
}
.team-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
}
.team-row.admin {
  grid-template-columns: repeat(5, 1fr);
  max-width: 1100px;
  margin: 0 auto;
}
.team-card {
  border-radius: 16px;
  overflow: hidden;
  transition: box-shadow .3s;
  display: flex;
  flex-direction: column;
  position: relative;
}
.team-card:hover {
  box-shadow: 0 16px 40px rgba(6,17,60,0.2);
}
a.team-card { color: inherit; }
.team-img {
  width: 100%;
  aspect-ratio: 3 / 4;
  background-size: cover;
  background-position: center top;
  background-color: #06113C;
  position: relative;
}
.team-card .team-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px 20px 20px;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);
  text-align: left;
  transition: padding-bottom .3s;
}
.team-card:hover .team-info { padding-bottom: 28px; }
.team-card .name { font-weight: 700; color: #fff; font-size: 1.05rem; transition: transform .3s; }
.team-card .role { color: rgba(255,255,255,0.75); font-size: 0.85rem; margin-top: 4px; font-weight: 500; transition: transform .3s; }
.team-card:hover .name,
.team-card:hover .role { transform: translateY(-6px); }
.team-card .team-more {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--orange);
  opacity: 0;
  max-height: 0;
  overflow: hidden;
  transform: translateY(10px);
  transition: opacity .3s, transform .3s, max-height .3s;
}
.team-card .team-more svg { width: 16px; height: 16px; }
.team-card:hover .team-more { opacity: 1; transform: translateY(0); max-height: 30px; }
.team .section-head h2,
.testimonials .section-head h2 { color: #fff; }
.team .section-head .eyebrow,
.testimonials .section-head .eyebrow { color: var(--orange); }
.team .section-head .lead,
.testimonials .section-head .lead { color: rgba(255,255,255,0.7); }
@media (max-width: 980px) { .team-row { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 560px) { .team-row { grid-template-columns: 1fr; } }

/* ---------- TESTIMONIALS ---------- */
section.video-testimonials-section { background: #fff; overflow: hidden; }
section.video-testimonials-section .section-head h2 { color: var(--navy); }
section.video-testimonials-section .section-head .eyebrow { color: var(--orange); }
.testimonials { background: var(--navy); overflow: hidden; }
.testi-track-wrap {
  overflow: hidden;
  -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
          mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
}
.testi-track {
  display: flex;
  gap: 24px;
  width: max-content;
  animation: scrollTesti 40s linear infinite;
}
.testi-track:hover { animation-play-state: paused; }
@keyframes scrollTesti {
  from { transform: translateX(0); }
  to { transform: translateX(calc(-50% - 12px)); }
}
.testi-card {
  width: clamp(320px, 40vw, 460px);
  background: #fff;
  border-radius: 12px;
  padding: 36px 32px;
  box-shadow: 0 4px 20px rgba(6,17,60,0.06);
  flex-shrink: 0;
  display: flex; flex-direction: column;
  min-height: 280px;
}
.testi-card .qmark {
  color: var(--orange);
  font-family: 'Georgia', serif;
  font-size: 3.6rem;
  line-height: 0.7;
  margin-bottom: 12px;
}
.testi-card .body {
  color: var(--navy);
  line-height: 1.6;
  font-size: 0.98rem;
  flex: 1;
}
.testi-card .who {
  margin-top: 24px;
  padding-top: 18px;
  border-top: 1px solid var(--navy-10);
  display: flex; flex-direction: column;
}
.testi-card .who .nm { font-weight: 700; color: var(--navy); font-size: 0.95rem; }
.testi-card .who .gr { color: var(--navy-50); font-size: 0.82rem; margin-top: 2px; }

/* ---------- STATS GRID ---------- */
.stats { background: var(--gray-light); }
.stats-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
}
.stat-item {
  text-align: center;
  padding: 36px 20px 32px;
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 4px 20px rgba(6,17,60,0.06);
  transition: transform .3s, box-shadow .3s;
  border: 1px solid transparent;
}
.stat-item:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 40px rgba(6,17,60,0.1);
  border-color: var(--orange);
}
.stat-icon {
  width: 48px;
  height: 48px;
  margin: 0 auto 16px;
  background: rgba(255,138,50,0.1);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--orange);
  transition: transform .3s, background .3s;
}
.stat-icon svg { width: 24px; height: 24px; }
.stat-item:hover .stat-icon {
  transform: scale(1.15) rotate(-5deg);
  background: var(--orange);
  color: #fff;
}
.stat-item:hover .stat-icon svg { stroke: #fff; }
.stat-item .cu,
.stat-item .stat-big {
  font-size: 2.6rem;
  font-weight: 700;
  color: var(--navy);
  display: inline;
}
.stat-item .suffix {
  font-size: 2.6rem;
  font-weight: 700;
  color: var(--navy);
}
.stat-label {
  display: block;
  margin-top: 10px;
  color: var(--navy-70);
  font-size: 0.88rem;
  line-height: 1.45;
}
@media (max-width: 1024px) { .stats-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 768px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .stats-grid { grid-template-columns: 1fr; } }

/* ---------- VIDEO TESTIMONIALS (about) ---------- */
.video-testimonials {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding: 12px 4px 20px;
}
.video-testimonials::-webkit-scrollbar { display: none; }
.video-testimonials { scrollbar-width: none; }
.video-card {
  flex: 0 0 300px;
  scroll-snap-align: start;
  border-radius: 16px;
  overflow: hidden;
  transition: box-shadow .25s;
}
.video-card:hover {
  box-shadow: 0 14px 32px rgba(6,17,60,0.12);
}
.video-thumb {
  position: relative;
  width: 100%;
  aspect-ratio: 9 / 14;
  background-size: cover;
  background-position: center;
  background-color: #06113C;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.video-play {
  width: 52px;
  height: 52px;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--navy);
  transition: transform .2s, background .2s;
}
.video-play svg { width: 22px; height: 22px; }
.video-card:hover .video-play {
  transform: scale(1.1);
  background: #fff;
}
.video-info {
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.video-name { font-weight: 600; font-size: 0.92rem; color: var(--navy); }
.video-role { font-size: 0.8rem; color: var(--navy-50); }
.video-wrap {
  position: relative;
}
.scroll-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2px 12px rgba(6,17,60,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--navy);
  transition: background .2s, color .2s;
}
.scroll-arrow:hover { background: var(--orange); color: #fff; }
.scroll-arrow svg { width: 20px; height: 20px; }
.scroll-left { left: -22px; }
.scroll-right { right: -22px; }
@media (max-width: 560px) {
  .video-card { flex: 0 0 240px; }
  .scroll-left { left: 4px; }
  .scroll-right { right: 4px; }
}

/* ---------- TEAM DESC ---------- */
.team-card .team-desc {
  margin-top: 10px;
  font-size: 0.82rem;
  color: var(--navy-70);
  line-height: 1.5;
  flex: 1;
}
.team-link {
  margin-top: 16px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--orange);
}
.team-card:hover .team-link { text-decoration: underline; }

/* ---------- USTOZ DETAIL ---------- */
.ustoz-detail { background: #fff; }
.ustoz-detail { padding-top: 120px; overflow: visible; }
.ustoz-grid {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 48px;
  align-items: start;
}
.ustoz-avatar { position: sticky; top: 120px; }
.ustoz-photo {
  width: 280px;
  height: 360px;
  background-size: cover;
  background-position: center top;
  border-radius: 12px;
  box-shadow: 0 12px 32px rgba(6,17,60,0.12);
}
.team-photo.big {
  width: 220px;
  height: 220px;
  font-size: 3.6rem;
  background: linear-gradient(135deg, #06113C 0%, #1a2660 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.5);
  font-weight: 700;
  border: none;
}
.ustoz-info h2 { font-size: 1.8rem; margin-bottom: 4px; }
.ustoz-role {
  color: var(--orange);
  font-weight: 600;
  font-size: 1rem;
  margin-bottom: 24px;
}
.ustoz-info p {
  color: var(--navy-90);
  margin-bottom: 14px;
  max-width: 60ch;
  line-height: 1.7;
}
.ustoz-meta {
  margin-top: 32px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 24px;
  background: var(--gray-light);
  border-radius: 10px;
}
.meta-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.meta-label {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--orange);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.meta-value {
  font-size: 0.92rem;
  color: var(--navy);
  line-height: 1.5;
}
.ustoz-info .btn-outline { margin-top: 32px; }
.btn-outline {
  display: inline-block;
  padding: 12px 28px;
  border: 2px solid var(--navy);
  border-radius: var(--radius);
  font-weight: 600;
  font-size: 0.92rem;
  color: var(--navy);
  transition: background .2s, color .2s;
}
.btn-outline:hover { background: var(--navy); color: #fff; }
@media (max-width: 768px) {
  .ustoz-grid { grid-template-columns: 1fr; justify-items: center; text-align: center; }
  .ustoz-avatar { position: static; }
  .ustoz-photo { width: 220px; height: 280px; }
  .ustoz-info p { max-width: 100%; }
}

/* ---------- APPLY SECTION ---------- */
.apply-section { background: var(--gray-light); }
.apply-form {
  max-width: 560px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.apply-form input,
.apply-form textarea {
  padding: 14px 18px;
  border-radius: var(--radius);
  border: 1px solid var(--navy-20);
  font-size: 0.95rem;
  transition: border-color .2s;
}
.apply-form input:focus,
.apply-form textarea:focus {
  outline: none;
  border-color: var(--orange);
}
.apply-form .btn { align-self: center; margin-top: 8px; }

/* ---------- GALLERY ---------- */
.gallery { background: #fff; }
.masonry {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-auto-rows: 180px;
  gap: 12px;
  grid-auto-flow: dense;
}
.masonry .tile {
  background: var(--navy);
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  cursor: pointer;
  transition: transform .25s;
}
.masonry .tile::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 30% 30%, rgba(255,255,255,0.04) 0%, transparent 60%),
    repeating-linear-gradient(45deg, transparent 0 16px, rgba(255,255,255,0.03) 16px 17px);
}
.masonry .tile .glyph {
  position: absolute;
  inset: 0;
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.18);
  font-weight: 700;
  font-size: 3rem;
  letter-spacing: 0.05em;
}
.masonry .tile .overlay {
  position: absolute; inset: 0;
  background: var(--orange);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-weight: 600;
  font-size: 0.92rem;
  letter-spacing: 0.04em;
  opacity: 0;
  transition: opacity .25s;
}
.masonry .tile:hover .overlay { opacity: 0.96; }
.masonry .tile.tall { grid-row: span 2; }
.masonry .tile.wide { grid-column: span 2; }
.gallery-cta { text-align: center; margin-top: 36px; }
@media (max-width: 880px) {
  .masonry { grid-template-columns: repeat(2, 1fr); }
  .masonry .tile.wide { grid-column: span 2; }
}
@media (max-width: 560px) {
  .masonry { grid-template-columns: 1fr; grid-auto-rows: 160px; }
  .masonry .tile.wide { grid-column: span 1; }
  .masonry .tile.tall { grid-row: span 1; }
}

/* ---------- COURSES ---------- */
.courses { background: var(--gray-light); }
.courses-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.course-card {
  background: #fff;
  border-radius: 10px;
  padding: 32px 26px;
  transition: .25s;
  display: flex; flex-direction: column; gap: 14px;
}
.course-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 14px 32px rgba(6,17,60,0.08);
}
.course-icon {
  width: 44px; height: 44px;
  color: var(--orange);
  margin-bottom: 4px;
}
.course-card h3 { font-size: 1.1rem; color: var(--navy); }
.course-card p { color: var(--navy-70); font-size: 0.9rem; line-height: 1.55; flex: 1; }
.course-card .text-link { font-size: 0.88rem; }
@media (max-width: 880px) { .courses-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .courses-grid { grid-template-columns: 1fr; } }

/* ---------- BLOG ---------- */
.blog { background: #fff; }
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.blog-card {
  border-radius: 10px;
  overflow: hidden;
  background: #fff;
  border: 1px solid var(--navy-10);
  transition: .25s;
  display: flex; flex-direction: column;
}
.blog-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 28px rgba(6,17,60,0.08);
  border-color: transparent;
}
.blog-img {
  aspect-ratio: 16/10;
  background: var(--navy);
  background-size: cover;
  background-position: center;
  position: relative;
  overflow: hidden;
}
.blog-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  position: absolute;
  top: 0;
  left: 0;
}
.blog-img-grant { background-image: linear-gradient(135deg, #10B981 0%, #059669 50%, #047857 100%); }
.blog-img-ielts { background-image: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%); }
.blog-img-qabul { background-image: linear-gradient(135deg, #0EA5E9 0%, #2563EB 100%); }
.blog-img-sat { background-image: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); }
.blog-img-uni { background-image: linear-gradient(135deg, #06113C 0%, #1E40AF 100%); }
.blog-img-karyera { background-image: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%); }
.blog-img-tavsiya { background-image: linear-gradient(135deg, #EC4899 0%, #BE185D 100%); }
.blog-img-otaona { background-image: linear-gradient(135deg, #FF8A32 0%, #EA580C 100%); }
.blog-img-til { background-image: linear-gradient(135deg, #14B8A6 0%, #0D9488 100%); }
.blog-img .blog-img-icon {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 48px; height: 48px;
  color: rgba(255,255,255,0.2);
}
.blog-img .badge {
  position: absolute;
  bottom: 14px; left: 14px;
  background: var(--orange);
  color: #fff;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 12px;
  border-radius: 4px;
}
.blog-body { padding: 24px; display: flex; flex-direction: column; gap: 12px; flex: 1; }
.blog-body h3 {
  font-size: 1.05rem;
  line-height: 1.4;
  color: var(--navy);
}
.blog-meta {
  color: var(--navy-50);
  font-size: 0.78rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.blog-body .text-link { font-size: 0.88rem; margin-top: auto; align-self: flex-start; }
.blog-cta { text-align: center; margin-top: 48px; }
@media (max-width: 880px) { .blog-grid { grid-template-columns: 1fr; max-width: 520px; margin: 0 auto; } }

/* ---------- FAQ ---------- */
.faq { background: var(--gray-light); }
.faq-list {
  max-width: 880px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.faq-item {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  transition: box-shadow .2s;
}
.faq-item.open { box-shadow: 0 6px 18px rgba(6,17,60,0.06); }
.faq-q {
  width: 100%;
  padding: 22px 26px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  font-weight: 600;
  color: var(--navy);
  text-align: left;
  font-size: 0.98rem;
  line-height: 1.4;
}
.faq-q .icon {
  width: 24px; height: 24px;
  flex-shrink: 0;
  color: var(--orange);
  font-size: 1.4rem;
  line-height: 1;
  transition: transform .25s;
  display: flex; align-items: center; justify-content: center;
}
.faq-item.open .faq-q .icon { transform: rotate(45deg); }
.faq-a {
  overflow: hidden;
  max-height: 0;
  transition: max-height .35s ease;
}
.faq-a-inner {
  padding: 0 26px 22px;
  color: var(--navy-70);
  line-height: 1.65;
  font-size: 0.95rem;
}

/* ---------- CONTACT ---------- */
.contact { background: #fff; }
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.contact-form label {
  display: flex; flex-direction: column; gap: 6px;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--navy);
  letter-spacing: 0.04em;
}
.contact-form input,
.contact-form select {
  border: 1px solid var(--navy-20);
  background: #fff;
  border-radius: 8px;
  padding: 14px 16px;
  font-size: 0.95rem;
  color: var(--navy);
  transition: border-color .2s;
  font-weight: 400;
}
.contact-form input:focus,
.contact-form select:focus {
  outline: none;
  border-color: var(--orange);
  box-shadow: 0 0 0 3px rgba(255,138,50,0.15);
}
.privacy-note {
  color: var(--navy-50);
  font-size: 0.78rem;
  line-height: 1.5;
  margin-top: 4px;
}
.form-success {
  display: none;
  background: rgba(255,138,50,0.08);
  border-left: 3px solid var(--orange);
  padding: 16px 18px;
  color: var(--navy);
  font-size: 0.92rem;
  border-radius: 6px;
  margin-top: 8px;
}
.form-success.show { display: block; }

.contact-info { display: flex; flex-direction: column; gap: 24px; }
.info-row {
  display: flex; align-items: center; gap: 16px;
  padding: 18px 20px;
  background: var(--gray-light);
  border-radius: 8px;
  transition: .2s;
}
.info-row a { font-weight: 600; color: var(--navy); }
.info-row .ic {
  width: 22px; height: 22px;
  color: var(--orange);
  flex-shrink: 0;
}
.info-row .lbl { font-size: 0.74rem; color: var(--navy-50); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }
.info-row .val { color: var(--navy); margin-top: 2px; font-weight: 500; font-size: 0.95rem; }
.info-row .col { display: flex; flex-direction: column; }
.telegram-btn {
  display: inline-flex;
  align-items: center; justify-content: center;
  gap: 12px;
  background: #229ED9;
  color: #fff;
  padding: 16px 24px;
  border-radius: 8px;
  font-weight: 600;
  transition: .2s;
}
.telegram-btn:hover { background: #1b86b8; transform: translateY(-2px); }
.telegram-btn .ic { width: 22px; height: 22px; color: #fff; }
@media (max-width: 880px) { .contact-grid { grid-template-columns: 1fr; gap: 48px; } }

/* ---------- FOOTER ---------- */
.footer {
  background: var(--navy);
  color: rgba(255,255,255,0.7);
  border-top: 3px solid var(--orange);
  padding: 64px 0 24px;
}
.footer-inner {
  display: grid;
  grid-template-columns: 1.4fr 1.6fr 1fr;
  gap: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.footer .logo { color: #fff; }
.footer p.desc {
  margin-top: 18px;
  font-size: 0.88rem;
  color: rgba(255,255,255,0.6);
  max-width: 32ch;
  line-height: 1.6;
}
.footer-nav {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px 24px;
}
.footer-nav a {
  color: rgba(255,255,255,0.6);
  font-size: 0.9rem;
  transition: color .2s;
}
.footer-nav a:hover { color: var(--orange); }
.footer-right { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
.footer-right .phone { color: #fff; font-weight: 600; font-size: 1.05rem; }
.footer-right .phone-lbl { font-size: 0.74rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; }
.socials { display: flex; gap: 10px; }
.social-btn {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.7);
  display: flex; align-items: center; justify-content: center;
  transition: .2s;
}
.social-btn:hover { background: var(--orange); color: #fff; }
.social-btn svg { width: 16px; height: 16px; }
.copyright {
  padding-top: 24px;
  text-align: center;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.5);
}
@media (max-width: 880px) {
  .footer-inner { grid-template-columns: 1fr; gap: 36px; }
}

/* ---------- Reveal animation ---------- */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity .7s ease, transform .7s ease;
}
.reveal.in { opacity: 1; transform: translateY(0); }
.reveal.delay-1 { transition-delay: .08s; }
.reveal.delay-2 { transition-delay: .16s; }
.reveal.delay-3 { transition-delay: .24s; }
.reveal.delay-4 { transition-delay: .32s; }

/* ---------- SCROLL PROGRESS ---------- */
.scroll-progress {
  position: fixed;
  top: 0; left: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--orange), #ffb347);
  width: 0%;
  z-index: 200;
  transition: width .1s linear;
  box-shadow: 0 0 8px rgba(255,138,50,0.5);
}

/* ---------- HERO PARTICLES ---------- */
.hero-particles {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.hero-particle {
  position: absolute;
  width: 4px; height: 4px;
  background: rgba(255,138,50,0.3);
  border-radius: 50%;
  animation: floatParticle linear infinite;
}
@keyframes floatParticle {
  0% { transform: translateY(0) scale(1); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(-100vh) scale(0.3); opacity: 0; }
}

/* ---------- TOP STUDENTS ---------- */
.top-students { background: var(--gray-light); }
.top-students-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.top-student-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(6,17,60,0.06);
  transition: transform .35s cubic-bezier(.23,1,.32,1), box-shadow .35s ease;
}
.top-student-card:hover {
  transform: translateY(-8px) scale(1.02);
  box-shadow: 0 20px 40px rgba(6,17,60,0.12);
}
.top-student-img {
  aspect-ratio: 1;
  background-size: cover;
  background-position: center;
  position: relative;
}
.top-student-img::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(6,17,60,0.6) 0%, transparent 60%);
}
.top-student-grant {
  position: absolute;
  top: 16px; right: 16px;
  background: var(--orange);
  color: #fff;
  padding: 6px 14px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.82rem;
  z-index: 2;
  letter-spacing: 0.02em;
}
.top-student-grant.glow {
  animation: grantGlow 2s ease-in-out infinite;
}
@keyframes grantGlow {
  0%, 100% { box-shadow: 0 0 8px rgba(255,138,50,0.3); }
  50% { box-shadow: 0 0 20px rgba(255,138,50,0.6), 0 0 40px rgba(255,138,50,0.2); }
}
.top-student-body {
  padding: 24px;
}
.top-student-uni {
  color: var(--orange);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.top-student-name {
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--navy);
  margin: 6px 0 10px;
}
.top-student-body p {
  color: var(--navy-70);
  font-size: 0.88rem;
  line-height: 1.55;
}
@media (max-width: 1024px) { .top-students-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .top-students-grid { grid-template-columns: 1fr; } }

/* ---------- AWARDS ---------- */
.awards { background: var(--navy); color: #fff; }
.awards .section-head h2 { color: #fff; }
.awards .section-head .sub { color: rgba(255,255,255,0.6); }
.awards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.award-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 36px 28px;
  text-align: center;
  transition: transform .3s, border-color .3s, background .3s;
}
.award-card:hover {
  transform: translateY(-6px);
  border-color: var(--orange);
  background: rgba(255,255,255,0.1);
}
.award-icon-wrap {
  width: 64px; height: 64px;
  margin: 0 auto 20px;
  transition: transform .4s ease;
}
.award-card:hover .award-icon-wrap {
  transform: rotateY(360deg);
}
.award-icon { width: 100%; height: 100%; }
.award-card h3 {
  font-size: 1.15rem;
  margin-bottom: 8px;
}
.award-card p {
  color: rgba(255,255,255,0.6);
  font-size: 0.88rem;
  line-height: 1.5;
  margin-bottom: 24px;
}
.award-medals {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 16px;
}
.medal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  font-size: 1.8rem;
  font-weight: 700;
  line-height: 1;
}
.medal.gold { color: #FFD700; }
.medal.silver { color: #C0C0C0; }
.medal.bronze { color: #CD7F32; }
.medal small {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
}
.award-total {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.5);
  padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.award-total strong { color: var(--orange); }
@media (max-width: 880px) { .awards-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; } }

/* ---------- ADVANTAGES ---------- */
.advantages { background: linear-gradient(180deg, #f8f9fc 0%, #fff 100%); }
.advantages-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.adv-card {
  padding: 36px 28px;
  border-radius: 16px;
  background: #fff;
  border: 1px solid rgba(6,17,60,0.06);
  border-top: 4px solid var(--navy);
  transition: transform .35s, box-shadow .35s, border-color .35s;
  position: relative;
  overflow: hidden;
}
.adv-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 48px rgba(6,17,60,0.1);
}

.adv-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 18px;
  transition: transform .35s, box-shadow .35s;
}
.adv-icon svg { width: 26px; height: 26px; }
.adv-card:hover .adv-icon { transform: scale(1.1) rotate(-4deg); }

.adv-accent-1 { border-top-color: #FF8A32; }
.adv-accent-1 .adv-icon { background: rgba(255,138,50,0.1); color: #FF8A32; }
.adv-accent-1:hover .adv-icon { box-shadow: 0 8px 20px rgba(255,138,50,0.25); }

.adv-accent-2 { border-top-color: #4F46E5; }
.adv-accent-2 .adv-icon { background: rgba(79,70,229,0.1); color: #4F46E5; }
.adv-accent-2:hover .adv-icon { box-shadow: 0 8px 20px rgba(79,70,229,0.25); }

.adv-accent-3 { border-top-color: #0EA5E9; }
.adv-accent-3 .adv-icon { background: rgba(14,165,233,0.1); color: #0EA5E9; }
.adv-accent-3:hover .adv-icon { box-shadow: 0 8px 20px rgba(14,165,233,0.25); }

.adv-accent-4 { border-top-color: #10B981; }
.adv-accent-4 .adv-icon { background: rgba(16,185,129,0.1); color: #10B981; }
.adv-accent-4:hover .adv-icon { box-shadow: 0 8px 20px rgba(16,185,129,0.25); }

.adv-accent-5 { border-top-color: #F59E0B; }
.adv-accent-5 .adv-icon { background: rgba(245,158,11,0.1); color: #F59E0B; }
.adv-accent-5:hover .adv-icon { box-shadow: 0 8px 20px rgba(245,158,11,0.25); }

.adv-num {
  display: inline-block;
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 12px;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  transition: opacity .3s;
}
.adv-accent-1 .adv-num { background-image: linear-gradient(135deg, #FF8A32, #ffb980); }
.adv-accent-2 .adv-num { background-image: linear-gradient(135deg, #4F46E5, #a5b4fc); }
.adv-accent-3 .adv-num { background-image: linear-gradient(135deg, #0EA5E9, #7dd3fc); }
.adv-accent-4 .adv-num { background-image: linear-gradient(135deg, #10B981, #6ee7b7); }
.adv-accent-5 .adv-num { background-image: linear-gradient(135deg, #F59E0B, #fcd34d); }

.adv-card h3 {
  font-size: 1.1rem;
  color: var(--navy);
  margin-bottom: 12px;
}
.adv-card p {
  color: var(--navy-70);
  font-size: 0.9rem;
  line-height: 1.6;
}
@media (max-width: 880px) { .advantages-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .advantages-grid { grid-template-columns: 1fr; } }

/* ---------- ADM DESC ---------- */
.adm-desc {
  color: rgba(255,255,255,0.7);
  font-size: 0.95rem;
  line-height: 1.6;
  margin-bottom: 28px;
}
.adm-desc strong { color: var(--orange); }
.step-desc {
  display: block;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.5);
  font-weight: 400;
  margin-top: 4px;
}
.adm-step > div { display: flex; flex-direction: column; }

/* ---------- CONTACT TEXTAREA ---------- */
.contact-form textarea {
  border: 1px solid var(--navy-20);
  background: #fff;
  border-radius: 8px;
  padding: 14px 16px;
  font-size: 0.95rem;
  color: var(--navy);
  transition: border-color .2s, box-shadow .2s;
  font-weight: 400;
  resize: vertical;
}
.contact-form textarea:focus {
  outline: none;
  border-color: var(--orange);
  box-shadow: 0 0 0 3px rgba(255,138,50,0.15);
}

/* ---------- PARTNER PILLS ---------- */
.uni-pill.partner {
  background: transparent;
  border: 1px solid var(--navy-20);
}
.uni-pill.partner:hover {
  background: var(--orange);
  border-color: var(--orange);
  color: #fff;
}

/* ---------- STATS ROW 6 col ---------- */
@media (min-width: 1101px) {
  .stats-row { grid-template-columns: repeat(6, 1fr); }
}

/* ---------- MICRO INTERACTIONS ---------- */
.stat-big:hover .num {
  transform: scale(1.1);
  transition: transform .3s ease;
}
.stat-big .num {
  transition: transform .3s ease;
  display: inline-block;
}
.hero-stat {
  transition: background .3s ease;
}
.hero-stat:hover {
  background: rgba(255,255,255,0.08);
}
.score-badge {
  transition: transform .2s, box-shadow .2s;
}
.result-card:hover .score-badge {
  transform: scale(1.1);
  box-shadow: 0 4px 12px rgba(255,138,50,0.3);
}

/* Stagger animation for uni pills */
[data-stagger].in .uni-pill {
  opacity: 0;
  animation: staggerIn .4s ease forwards;
}
[data-stagger].in .uni-pill:nth-child(1) { animation-delay: 0s; }
[data-stagger].in .uni-pill:nth-child(2) { animation-delay: .05s; }
[data-stagger].in .uni-pill:nth-child(3) { animation-delay: .1s; }
[data-stagger].in .uni-pill:nth-child(4) { animation-delay: .15s; }
[data-stagger].in .uni-pill:nth-child(5) { animation-delay: .2s; }
[data-stagger].in .uni-pill:nth-child(6) { animation-delay: .25s; }
[data-stagger].in .uni-pill:nth-child(7) { animation-delay: .3s; }
[data-stagger].in .uni-pill:nth-child(8) { animation-delay: .35s; }
[data-stagger].in .uni-pill:nth-child(9) { animation-delay: .4s; }
[data-stagger].in .uni-pill:nth-child(10) { animation-delay: .45s; }
[data-stagger].in .uni-pill:nth-child(11) { animation-delay: .5s; }
[data-stagger].in .uni-pill:nth-child(12) { animation-delay: .55s; }
[data-stagger].in .uni-pill:nth-child(13) { animation-delay: .6s; }
[data-stagger].in .uni-pill:nth-child(14) { animation-delay: .65s; }
[data-stagger].in .uni-pill:nth-child(15) { animation-delay: .7s; }
[data-stagger].in .uni-pill:nth-child(16) { animation-delay: .75s; }
@keyframes staggerIn {
  from { opacity: 0; transform: translateY(12px) scale(0.9); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* Input focus glow */
.contact-form input:focus,
.contact-form select:focus,
.contact-form textarea:focus {
  animation: focusPulse .6s ease;
}
@keyframes focusPulse {
  0% { box-shadow: 0 0 0 0 rgba(255,138,50,0.3); }
  50% { box-shadow: 0 0 0 6px rgba(255,138,50,0.15); }
  100% { box-shadow: 0 0 0 3px rgba(255,138,50,0.15); }
}

/* ---------- MASHGULOTLAR PAGE ---------- */

/* Grant banner */
.mash-grant-banner {
  background: var(--navy);
  padding: clamp(48px, 6vw, 80px) 0;
}
.grant-banner-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
  text-align: center;
}
.grant-stat { padding: 0 16px; }
.grant-dollar {
  display: block;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  color: var(--orange);
  line-height: 1.1;
  margin-bottom: 8px;
}
.grant-label {
  display: block;
  font-size: 0.85rem;
  font-weight: 500;
  color: rgba(255,255,255,0.6);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.grant-desc {
  text-align: center;
  color: rgba(255,255,255,0.7);
  max-width: 600px;
  margin: 32px auto 0;
  font-size: 0.95rem;
  line-height: 1.65;
}
@media (max-width: 640px) {
  .grant-banner-inner { grid-template-columns: repeat(2, 1fr); gap: 24px; }
}

/* Exam grid */
.mash-exams { background: #f8f9fc; }
.mash-exam-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32px;
  margin-top: 48px;
}
.mash-exam-card {
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(6,17,60,0.06);
  display: flex;
  flex-direction: column;
  transition: transform .35s, box-shadow .35s;
}
.mash-exam-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 48px rgba(6,17,60,0.1);
}
.mash-exam-header {
  padding: 36px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}
.mash-exam-ielts { background: linear-gradient(135deg, #4F46E5, #7C3AED); }
.mash-exam-sat { background: linear-gradient(135deg, #0EA5E9, #2563EB); }

.mash-exam-badge {
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: 0.08em;
}
.mash-exam-score { text-align: right; }
.mash-score-label {
  display: block;
  font-size: 0.75rem;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.mash-score-num {
  font-size: 2.6rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.mash-exam-body {
  padding: 32px;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.mash-exam-body p {
  color: var(--navy-70);
  line-height: 1.7;
  margin-bottom: 16px;
}
.mash-exam-facts {
  list-style: none;
  padding: 0;
  margin: 0 0 16px;
}
.mash-exam-facts li {
  padding: 8px 0;
  border-bottom: 1px solid rgba(6,17,60,0.06);
  font-size: 0.92rem;
  color: var(--navy-90);
}
.mash-exam-facts li:last-child { border-bottom: none; }
.mash-exam-note {
  font-size: 0.85rem;
  color: var(--navy-50);
  font-style: italic;
}
@media (max-width: 768px) {
  .mash-exam-grid { grid-template-columns: 1fr; }
}

/* Subjects */
.mash-subjects { background: #fff; }
.mash-subjects-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32px;
  margin-top: 48px;
}
.mash-subject-block {
  padding: 40px 32px;
  border-radius: 20px;
  border: 1px solid rgba(6,17,60,0.06);
  text-align: center;
  transition: transform .3s, box-shadow .3s;
}
.mash-subject-block:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 36px rgba(6,17,60,0.08);
}
.mash-subject-icon {
  width: 64px; height: 64px;
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
}
.mash-subject-icon svg { width: 30px; height: 30px; }
.mash-icon-academic { background: rgba(79,70,229,0.1); color: #4F46E5; }
.mash-icon-tarbiya { background: rgba(245,158,11,0.1); color: #F59E0B; }

.mash-subject-block h3 {
  font-size: 1.15rem;
  color: var(--navy);
  margin-bottom: 20px;
}
.mash-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
}
.mash-tag {
  display: inline-block;
  padding: 8px 18px;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 600;
  background: #f0f1f5;
  color: var(--navy);
  transition: background .2s, color .2s, transform .2s;
}
.mash-tag:hover {
  background: var(--navy);
  color: #fff;
  transform: translateY(-2px);
}
@media (max-width: 640px) {
  .mash-subjects-row { grid-template-columns: 1fr; }
}

/* Extra activities */
.mash-extra { background: #f8f9fc; }
.mash-extra-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28px;
  margin-top: 48px;
}
.mash-extra-card {
  padding: 36px 28px;
  background: #fff;
  border-radius: 20px;
  border: 1px solid rgba(6,17,60,0.06);
  text-align: center;
  transition: transform .3s, box-shadow .3s;
}
.mash-extra-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 40px rgba(6,17,60,0.08);
}
.mash-extra-visual {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: rgba(255,138,50,0.1);
  color: var(--orange);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
}
.mash-extra-visual svg { width: 28px; height: 28px; }
.mash-extra-card h3 { font-size: 1.1rem; color: var(--navy); margin-bottom: 12px; }
.mash-extra-card p { color: var(--navy-70); font-size: 0.9rem; line-height: 1.65; margin-bottom: 16px; }
.mash-extra-card .text-link { font-size: 0.88rem; }
@media (max-width: 880px) { .mash-extra-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .mash-extra-grid { grid-template-columns: 1fr; } }

/* CTA */
.mash-cta { background: linear-gradient(135deg, #06113C 0%, #1a2660 100%); }
.mash-cta-inner {
  text-align: center;
  max-width: 640px;
  margin: 0 auto;
}
.mash-cta-inner h2 { color: #fff; margin-bottom: 16px; }
.mash-cta-inner p { color: rgba(255,255,255,0.75); margin-bottom: 32px; font-size: 1.05rem; }
.mash-cta-inner strong { color: #fff; }
.mash-cta-actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

/* ---------- BLOG DETAIL ---------- */
.blog-detail {
  padding: 120px 0 var(--section-y);
  background: #fff;
}
.blog-detail .container { max-width: 760px; }
.blog-detail-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}
.blog-detail-header .badge {
  display: inline-block;
  padding: 6px 14px;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  background: var(--orange);
  color: #fff;
}
.blog-detail-header .blog-meta {
  font-size: 0.85rem;
  color: var(--navy-50);
}
.blog-detail h1 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--navy);
  margin-bottom: 40px;
  line-height: 1.25;
}
.blog-detail-hero {
  margin-bottom: 40px;
  border-radius: 12px;
  overflow: hidden;
}
.blog-detail-hero img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}
.blog-detail-content h2 {
  font-size: 1.3rem;
  color: var(--navy);
  margin: 36px 0 16px;
}
.blog-detail-content p {
  color: var(--navy-90);
  line-height: 1.8;
  margin-bottom: 16px;
  font-size: 1.02rem;
}
.blog-detail-content ul {
  margin: 0 0 20px 24px;
  list-style: disc;
}
.blog-detail-content li {
  color: var(--navy-90);
  line-height: 1.8;
  margin-bottom: 8px;
  font-size: 1rem;
}
.blog-detail-content strong { color: var(--navy); }
.blog-detail-footer {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--navy-10);
}
.btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border: 1.5px solid var(--navy-20);
  border-radius: var(--radius);
  color: var(--navy);
  font-weight: 600;
  font-size: 0.92rem;
  transition: border-color .2s, color .2s, background .2s;
}
.btn-outline:hover {
  border-color: var(--orange);
  color: var(--orange);
  background: rgba(255,138,50,0.04);
}

::selection { background: var(--orange); color: #fff; }

/* ---------- Language switcher (added by Next.js port) ---------- */
.lang-switcher { display: inline-flex; align-items: center; gap: 4px; padding: 4px; border: 1px solid rgba(255,255,255,0.18); border-radius: 999px; }
.header.scrolled .lang-switcher,
.header.solid .lang-switcher { border-color: rgba(6,17,60,0.12); }
.lang-btn { font-family: inherit; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; color: rgba(255,255,255,0.7); padding: 6px 10px; border-radius: 999px; background: transparent; transition: background .15s, color .15s; }
.header.scrolled .lang-btn,
.header.solid .lang-btn { color: var(--navy-50); }
.lang-btn:hover { color: var(--orange); }
.lang-btn.active { background: var(--orange); color: #fff; }
.header.scrolled .lang-btn.active,
.header.solid .lang-btn.active { color: #fff; }

@media (max-width: 900px) {
  .lang-switcher { order: 3; }
}

/* Smooth content fallback for missing images on testimonial videos */
.video-thumb { background-color: var(--navy-10); }
